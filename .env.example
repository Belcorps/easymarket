# NextAuth (générer une clé : openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here
# En local : http://localhost:3000 — En prod : https://votre-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Base de données (obligatoire) — Supabase > Project Settings > Database > Connection string (URI)
# Utiliser le mode "Session" (port 6543) pour Vercel / serverless
DATABASE_URL=postgresql://postgres.[ref]:[MOT_DE_PASSE]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase — pour stocker logos et images produits en production (Vercel)
# Project Settings > API : Project URL et service_role key (secret)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optionnel : un compte admin (cet e-mail voit le menu Admin)
# ADMIN_EMAIL=admin@exemple.com

# Optionnel : suppression de l'arrière-plan (logo + photo produit) (https://www.remove.bg/api)
# REMOVE_BG_API_KEY=your-remove-bg-api-key
